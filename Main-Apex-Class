public class PS_SalesforceTokenUtils {

    public PageReference getAuthCode(){
            /* Get the custom metadata record */
        Salesforce_Config__mdt  config = Salesforce_Config__mdt.getInstance(System.Label.PS_Salesforce_token_Label); //Use custom Label
         // First we need to prepare the below url and return it 
         //https://login.salesforce.com/services/oauth2/authorize?client_id=3MVG9vIoc6tt9pNleIOuFlHm4wvRTq215PfDxGDA6ewfpbgOixpqIM6XdB7a1mzLEmvUbaBDJ_wxtae.nGWFO&
         //redirect_uri=https://login.salesforce.com/services/oauth2/success&
         //response_type=code
           
        If(config!=null){
         string orgURL = config.Environment__c=='Production'? 'https://login.salesforce.com/' : 'https://test.salesforce.com/';
         string redirecturi=System.URL.getOrgDomainURL().toExternalForm()+'/apex/PS_SalesforceTokenPage';
         string OauthURL=orgURL+config.auth_url__c+'?client_id='+config.client_id__c+'&redirect_uri='+redirecturi+'&response_type=code';
         System.debug(OauthURL);
         return new PageReference(OauthURL);
        }
        else{
            return null;
        }       
    }
    public void getAccessToken(){
        
        Salesforce_Config__mdt  config = Salesforce_Config__mdt.getInstance(System.Label.PS_Salesforce_token_Label); //Use custom Label
        system.debug('Lable salesforce token'+System.Label.PS_Salesforce_token_Label);
        If(config!=null){
        //here we are fetching the url so that we can access code
       
        string code= ApexPages.currentPage().getParameters().get('code');
        string orgURL = config.Environment__c=='Production'? 'https://login.salesforce.com/' : 'https://test.salesforce.com/';
        string tokenURL=orgURL+config.Token_url__c;
        string redirect_uri=System.URL.getOrgDomainURL().toExternalForm()+'/apex/PS_SalesforceTokenPage';
        string requestBody='code='+code+'&grant_type=authorization_code&client_id='+config.client_id__c+'&client_secret='+config.client_secret__c
        +'&redirect_uri='+redirect_uri;
       // system.debug(config.client_id__c);
        HttpRequest httpreq=new HttpRequest();
        httpreq.setEndpoint(tokenURL);
        httpreq.setMethod('POST');
        httpreq.setBody(requestBody);
       // system.debug(requestBody);
        httpreq.setHeader('Content-Type','application/x-www-form-urlencoded');
        httpreq.setHeader('Accept', 'application/json');
      //  system.debug()
         Http htt=new Http();
        //    HttpResponse httresponses=htt.send(httpreq);
        // system.debug(httresponses.getStatusCode());
        try {
            
            HttpResponse httresponse=htt.send(httpreq);
            if(httresponse.getStatusCode() == 200){
                 system.debug(httresponse.getStatusCode());
               PS_SalesforceTokenWrapper wrapper=(PS_SalesforceTokenWrapper)System.JSON.deserialize(httresponse.getBody(),PS_SalesforceTokenWrapper.class);
                
                //we will deploy this to custom metadata
                //full name will be metadata objectname.recordname
                
                string fullname='Salesforce_Config.'+System.Label.PS_Salesforce_token_Label;
                string label=System.Label.PS_Salesforce_token_Label;
                Map<String,Object>fieldWithValuesMap=new Map<String,Object>();
                
                    fieldWithValuesMap.put('access__c',wrapper.access_token);
                    //fieldWithValuesMap.put('ex__c',wrapper.);
                    fieldWithValuesMap.put('expires_in_time__c', System.now().addHours(2) );
                    fieldWithValuesMap.put('Instance_Url__c', wrapper.instance_url);
                    fieldWithValuesMap.put('refresh_token__c', wrapper.refresh_token);
                    fieldWithValuesMap.put('scope__c',wrapper.scope);
                   // fieldWithValuesMap.put('clientid__c',config.clientid__c);
                    fieldWithValuesMap.put('client_secret__c',config.client_secret__c );
                    CreateUpdateMetadataUtils.createUpdateMetadata(fullName, label, fieldWithValuesMap);
                
                    ApexPages.addmessage(new ApexPages.message(ApexPages.severity.CONFIRM,'Successfull!'));
                
                System.debug('Success'+httresponse.getBody());
            }
            else{
                  ApexPages.addmessage(new ApexPages.message(ApexPages.severity.ERROR,'error'));

            }
           } catch(Exception ex){
                //
               // ApexPages.addmessage(new ApexPages.message(ApexPages.severity.ERROR);
            }
                        
    }
    } 
}
